# Environment variable template — copy this file to .env.local for local development.
# .env.local is gitignored. Never commit real values to .env.
#
# All NEXT_PUBLIC_* variables are baked into the client bundle at build time.
# Set the appropriate value in your deployment environment (Vercel, Docker, CI, etc.)
# before running `next build`.

# Base URL of the BFF (no trailing slash). The app talks ONLY to the BFF, which
# owns auth/session (cookie at /auth/*) and reverse-proxies API calls to the
# backend services under per-service prefixes (/bff/workflow-backend, /bff/user-service).
# Examples:
#   Local dev:  http://localhost:8090
#   Production: https://bff.example.com
NEXT_PUBLIC_BFF_URL=
