# Environment variable template — copy this file to .env.local for local development.
# .env.local is gitignored. Never commit real values to .env.
#
# LOCAL DEV:
#   Any NEXT_PUBLIC_* var here is read by `next dev` / local `next build`.
#
# DOCKER / PRODUCTION (single image, config via env vars):
#   The published image bakes NOTHING in. The server reads process.env at request
#   time (loadRuntimeConfig) and passes EVERY NEXT_PUBLIC_* var (prefix stripped)
#   to the client via RuntimeConfigProvider — no window globals, no startup script.
#   So one image serves every deployment — no per-config .env files, no per-config
#   CI. Adding config = pass another NEXT_PUBLIC_* var:
#     docker run \
#       -e NEXT_PUBLIC_BFF_URL=https://bff.example.com \
#       -e NEXT_PUBLIC_FEATURE_X=true \
#       ghcr.io/<owner>/workflow-frontend
#   (The legacy unprefixed BFF_URL is still accepted for backward compatibility.)

# Base URL of the BFF (no trailing slash). The app talks ONLY to the BFF, which
# owns auth/session (cookie at /auth/*) and reverse-proxies API calls to the
# backend services under per-service prefixes (/bff/workflow-backend, /bff/user-service).
# Examples:
#   Local dev:  http://localhost:8090
#   Production: https://bff.example.com
NEXT_PUBLIC_BFF_URL=
