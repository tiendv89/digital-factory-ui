# Comma-separated list of workspace root paths, each containing a workspace.yaml.
# Example: WORKSPACE_LIST=/path/to/ws1,/path/to/ws2
WORKSPACE_LIST=/path/to/workspace

# Git commit identity for Server Actions that write back to status.yaml.
GIT_AUTHOR_NAME=your-name
GIT_AUTHOR_EMAIL=your-email@example.com

# SSH private key path used by simple-git for authenticated git push.
SSH_KEY_PATH=~/.ssh/id_ed25519
