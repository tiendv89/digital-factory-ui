# Path to the local clone of the management repo.
# The app reads feature and task YAML files from this directory at runtime.
# Example: /Users/yourname/workspace/project-workspace
WORKSPACE_MGMT_PATH=

# Controls which data source implementation is used.
# Leave unset (or set to "filesystem") for local development.
# Set to "static" when building for GitHub Pages (enables output:'export'
# and selects StaticFeatureRepository, which reads pre-generated JSON
# from public/data/ instead of live YAML files).
# NEXT_PUBLIC_DATA_SOURCE=static
